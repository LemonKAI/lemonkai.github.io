---
import type { TranslationPair } from "../utils/blog";
import { formatDate, postUrl } from "../utils/blog";

interface Props {
  pair: TranslationPair;
}

const { pair } = Astro.props;
const leadPost = pair.zh ?? pair.en;
const chapter = pair.seriesOrder
  ? String(pair.seriesOrder).padStart(2, "0")
  : "??";
const summaryTitle = pair.zh?.data.title ?? pair.en?.data.title ?? "Series chapter";
const status = pair.zh && pair.en ? "ZH + EN" : pair.zh ? "ZH first" : "EN only";
---

<article class="chapter-row">
  <div class="chapter-row__summary">
    <p class="eyebrow">
      Chapter {chapter}
      <span class="chapter-row__status">{status}</span>
    </p>
    <h3>{summaryTitle}</h3>
    <p>
      {leadPost?.data.description ??
        "A bilingual chapter pair for the main Kubernetes series."}
    </p>
  </div>

  <div class="chapter-row__tracks">
    {
      pair.zh ? (
        <a class="chapter-card chapter-card--zh" href={postUrl(pair.zh)}>
          <span class="chapter-card__label">中文稿</span>
          <h4>{pair.zh.data.title}</h4>
          <p>{pair.zh.data.description}</p>
          <div class="chapter-card__meta">
            <time datetime={pair.zh.data.pubDate.toISOString()}>
              {formatDate(pair.zh.data.pubDate, "zh")}
            </time>
            <span>閱讀主線</span>
          </div>
        </a>
      ) : (
        <div class="chapter-card chapter-card--empty">
          <span class="chapter-card__label">中文稿</span>
          <h4>撰寫中</h4>
          <p>這個章節的中文版還在整理，會優先補上主線內容。</p>
        </div>
      )
    }

    {
      pair.en ? (
        <a class="chapter-card chapter-card--en" href={postUrl(pair.en)}>
          <span class="chapter-card__label">English</span>
          <h4>{pair.en.data.title}</h4>
          <p>{pair.en.data.description}</p>
          <div class="chapter-card__meta">
            <time datetime={pair.en.data.pubDate.toISOString()}>
              {formatDate(pair.en.data.pubDate, "en")}
            </time>
            <span>Read track</span>
          </div>
        </a>
      ) : (
        <div class="chapter-card chapter-card--empty">
          <span class="chapter-card__label">English</span>
          <h4>In progress</h4>
          <p>The English version of this chapter is planned as part of the core track.</p>
        </div>
      )
    }
  </div>
</article>
