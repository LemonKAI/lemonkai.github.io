---
import { SITE_AUTHOR, SITE_TAGLINE, SITE_TITLE } from "../consts";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
const currentLang = lang.startsWith("zh") ? "zh" : "en";

const links = [
  { href: "/", label: "首頁", note: "Notebook" },
  { href: "/series/kai-k8s-road/", label: "K8s之路", note: "主線" },
  { href: "/blog/", label: "全部文章", note: "Archive" },
  { href: "/about/", label: "關於", note: "About" }
];

const languageLinks = [
  { href: "/blog/zh/", label: "繁中主稿", note: "Zh.", lang: "zh" },
  { href: "/blog/en/", label: "English mirror", note: "En.", lang: "en" }
];
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="site-brand" href="/">
      <span class="site-brand__mark">KAI</span>
      <span class="site-brand__copy">
        <small>{SITE_TITLE}</small>
        <strong>KAI K8s之路</strong>
        <em>{SITE_AUTHOR} · {SITE_TAGLINE}</em>
      </span>
    </a>

    <div class="site-header__cluster">
      <nav aria-label="Primary navigation">
        <ul class="site-nav">
          {
            links.map((link) => {
              const active =
                link.href === "/"
                  ? currentPath === "/"
                  : currentPath.startsWith(link.href);

              return (
                <li>
                  <a href={link.href} data-active={active ? "true" : undefined}>
                    <span>{link.label}</span>
                    <small>{link.note}</small>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <div class="site-language-switch" aria-label="Language links">
        <span class="site-language-switch__label">閱讀語言</span>
        {
          languageLinks.map((link) => {
            const active =
              currentPath.startsWith(link.href) || currentLang === link.lang;

            return (
              <a href={link.href} data-active={active ? "true" : undefined}>
                <span>{link.label}</span>
                <small>{link.note}</small>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</header>
