---
import { SITE_AUTHOR, SITE_TAGLINE, SITE_TITLE } from "../consts";

const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/series/kai-k8s-road/", label: "Series" },
  { href: "/blog/", label: "Blog" },
  { href: "/about/", label: "About" }
];

const languageLinks = [
  { href: "/blog/zh/", label: "中文" },
  { href: "/blog/en/", label: "EN" }
];
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="site-brand" href="/">
      <span class="site-brand__mark">lk</span>
      <span>
        <strong>{SITE_TITLE}</strong>
        <small>{SITE_AUTHOR} · {SITE_TAGLINE}</small>
      </span>
    </a>

    <div class="site-header__cluster">
      <nav aria-label="Primary navigation">
        <ul class="site-nav">
          {
            links.map((link) => {
              const active =
                link.href === "/"
                  ? currentPath === "/"
                  : currentPath.startsWith(link.href);

              return (
                <li>
                  <a href={link.href} data-active={active ? "true" : undefined}>
                    {link.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <div class="site-language-switch" aria-label="Language links">
        {
          languageLinks.map((link) => {
            const active = currentPath.startsWith(link.href);

            return (
              <a href={link.href} data-active={active ? "true" : undefined}>
                {link.label}
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</header>
