---
import type { CollectionEntry } from "astro:content";
import {
  formatDate,
  kindLabel,
  languageLabel,
  postUrl
} from "../utils/blog";
import TagPill from "./TagPill.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const readLabel = post.data.lang === "zh" ? "閱讀這篇筆記" : "Read this note";
const lane = {
  series: post.data.lang === "zh" ? "KAI notebook" : "Mainline note",
  incident: post.data.lang === "zh" ? "Production field notes" : "Production field notes",
  note: post.data.lang === "zh" ? "Concept artifact" : "Concept artifact"
}[post.data.kind];
---

<article class:list={["post-card", `post-card--${post.data.kind}`]}>
  <div class="post-card__eyebrow">
    <span class="meta-pill">{languageLabel(post.data.lang)}</span>
    <span class="meta-pill">{kindLabel(post.data.kind, post.data.lang)}</span>
    {
      post.data.seriesOrder && (
        <span class="meta-pill">#{String(post.data.seriesOrder).padStart(2, "0")}</span>
      )
    }
  </div>

  {
    post.data.series && <p class="post-card__series">{post.data.series}</p>
  }

  <p class="post-card__lane">{lane}</p>

  <h2 class="post-card__title">
    <a href={postUrl(post)}>{post.data.title}</a>
  </h2>

  <p class="post-card__description">{post.data.description}</p>

  <div class="post-card__footer">
    <div class="post-card__meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate, post.data.lang)}
      </time>
      <span>{post.data.tags.length} tags</span>
    </div>
    <span class="post-card__cta">{readLabel}</span>
  </div>

  <div class="tag-list">
    {post.data.tags.map((tag) => <TagPill tag={tag} />)}
  </div>
</article>
