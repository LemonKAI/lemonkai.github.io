---
import type { CollectionEntry } from "astro:content";
import {
  formatDate,
  kindLabel,
  languageLabel,
  postUrl
} from "../utils/blog";
import TagPill from "./TagPill.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<article class="post-card">
  <div class="post-card__eyebrow">
    <span class="meta-pill">{languageLabel(post.data.lang)}</span>
    <span class="meta-pill">{kindLabel(post.data.kind, post.data.lang)}</span>
    {
      post.data.seriesOrder && (
        <span class="meta-pill">#{post.data.seriesOrder}</span>
      )
    }
  </div>

  <div class="post-card__meta">
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate, post.data.lang)}
    </time>
    <span>{post.data.tags.length} tags</span>
  </div>

  <h2 class="post-card__title">
    <a href={postUrl(post)}>{post.data.title}</a>
  </h2>

  <p class="post-card__description">{post.data.description}</p>

  <div class="tag-list">
    {post.data.tags.map((tag) => <TagPill tag={tag} />)}
  </div>
</article>
