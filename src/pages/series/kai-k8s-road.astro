---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import SeriesPairRow from "../../components/SeriesPairRow.astro";
import { FEATURED_SERIES_NAME } from "../../consts";
import {
  getPostsByKind,
  getSeriesPosts,
  getSortedPosts,
  getTranslationPairs,
  sortSeriesPosts
} from "../../utils/blog";

const allPosts = await getSortedPosts();
const seriesPosts = sortSeriesPosts(getSeriesPosts(allPosts, FEATURED_SERIES_NAME));
const seriesPairs = getTranslationPairs(seriesPosts);
const sideNotes = getPostsByKind(allPosts, "incident").concat(
  allPosts.filter((post) => post.data.kind === "note").slice(0, 2)
);

const roadmap = [
  {
    chapter: "01",
    title: "Pod 是第一個邊界",
    question: "Kubernetes 為什麼不直接管理 container？",
    model: "Container 是執行單位，Pod 是編排單位。",
    status: "published"
  },
  {
    chapter: "02",
    title: "Deployment 是變更控制器",
    question: "有了 Pod，為什麼還需要 Deployment？",
    model: "不要手動照顧每個 Pod，要讓 controller 管 rollout。",
    status: "next"
  },
  {
    chapter: "03",
    title: "Service 是穩定入口",
    question: "Pod 一直變，流量怎麼找到它？",
    model: "Service 把易變的 Pod 包成穩定的網路身份。",
    status: "planned"
  },
  {
    chapter: "04",
    title: "Probe 是信任邊界",
    question: "Running 為什麼不代表可以接流量？",
    model: "Readiness 管接流量，liveness 管是否該重啟。",
    status: "planned"
  },
  {
    chapter: "05",
    title: "GitOps 是變更路線",
    question: "怎樣讓 production 變更可審、可回放？",
    model: "把 cluster 狀態放進一條可追的提交歷史。",
    status: "planned"
  }
];

const method = [
  "先講我為什麼現在要理解它",
  "再給一句能記住的核心判斷",
  "接著把概念變成一個心智模型",
  "最後接到下一章會遇到的真問題"
];
---

<BaseLayout
  title="KAI K8s之路"
  description="KAI K8s之路：Kai Ning 的 Kubernetes 主線系列。不是知識點清單，而是一條從 Pod 到 production 的個人 infra notebook。"
  lang="zh-Hant"
>
  <section class="page-intro page-intro--with-rail page-intro--notebook">
    <div class="page-intro__copy">
      <p class="eyebrow">Series hub / 主線入口</p>
      <h1>KAI K8s之路</h1>
      <p>
        這條主線不是把 Kubernetes 名詞照順序排完，而是把一個工程師真正會卡住的問題慢慢接起來。
        先理解 Pod，才知道 Deployment 在幫你解什麼；理解 rollout，才知道為什麼 probe 和 observability 不是裝飾品。
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="#chapters">從章節開始</a>
        <a class="button" href="/blog/zh/">看中文文章</a>
        <a class="button" href="/blog/en/">Read English track</a>
      </div>
    </div>

    <aside class="page-intro__aside series-contract">
      <p class="signal-panel__label">Series contract / 寫作契約</p>
      <ul class="signal-panel__list">
        {method.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Route map</p>
      <h2>每一章都要回答一個真問題</h2>
    </div>
  </section>

  <section class="route-map">
    {roadmap.map((item) => (
      <article class:list={["route-card", `route-card--${item.status}`]}>
        <div class="route-card__index">{item.chapter}</div>
        <div class="route-card__body">
          <p class="eyebrow">{item.status}</p>
          <h3>{item.title}</h3>
          <p>{item.question}</p>
          <strong>{item.model}</strong>
        </div>
      </article>
    ))}
  </section>

  <section class="section-header" id="chapters">
    <div>
      <p class="eyebrow">Chapter pairs</p>
      <h2>章節不是文章，是主線上的節點</h2>
    </div>
  </section>

  <section class="chapter-stack">
    {seriesPairs.map((pair) => <SeriesPairRow pair={pair} />)}
  </section>

  <section class="notebook-panel">
    <div>
      <p class="eyebrow">How to read</p>
      <h2>讀這個系列時，我希望你不要急著背 YAML</h2>
      <p>
        YAML 很快可以查到。真正難的是先知道每個資源在 Kubernetes 裡負責哪一段邊界。
        這條主線會盡量把每個概念變成一句能記住的判斷，讓後面 debug 和設計時能回來用。
      </p>
    </div>
    <div class="notebook-panel__quote">
      <span>Core bias</span>
      <strong>先理解邊界，再看配置。</strong>
    </div>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Related notes</p>
      <h2>支線筆記：主線旁邊的 production 回聲</h2>
    </div>
  </section>

  <section class="post-list post-list--secondary">
    {sideNotes.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
