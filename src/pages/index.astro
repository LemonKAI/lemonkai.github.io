---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SeriesPairRow from "../components/SeriesPairRow.astro";
import { FEATURED_SERIES_NAME, SITE_AUTHOR, SITE_TITLE } from "../consts";
import {
  getPostsByKind,
  getSeriesPosts,
  getSortedPosts,
  getTranslationPairs,
  getTagCounts,
  sortSeriesPosts
} from "../utils/blog";

const posts = await getSortedPosts();
const topTags = getTagCounts(posts).slice(0, 6);
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const seriesPairs = getTranslationPairs(seriesPosts);
const featuredPair = seriesPairs[0];
const sidePosts = posts.filter((post) => post.data.kind !== "series").slice(0, 4);
const notePosts = getPostsByKind(posts, "note");
const incidentPosts = getPostsByKind(posts, "incident");

const route = [
  { step: "01", title: "Pod", detail: "先知道 Kubernetes 到底在照顧哪一組程式。" },
  { step: "02", title: "Deployment", detail: "再理解更新、回滾與 rollout 怎麼發生。" },
  { step: "03", title: "Service", detail: "接著看流量如何找到 workload。" },
  { step: "04", title: "Probe", detail: "把健康檢查和重啟邏輯拆開。" },
  { step: "05", title: "GitOps", detail: "最後把變更交給一條可審計的路。" }
];

const principles = [
  {
    title: "不是百科，是心智路線",
    copy: "每篇先回答：我為什麼現在要理解它、我會怎麼記住它、它後面會影響哪些問題。"
  },
  {
    title: "不是摘要，是 KAI 的理解",
    copy: "同一個 Kubernetes 概念，要寫出我會怎麼看、怎麼 debug、怎麼把它放進下一章。"
  },
  {
    title: "不是孤立文章，是一條主線",
    copy: "Pod 會接到 Deployment，Deployment 會接到 rollout，rollout 最後一定會遇到 observability 和 incident。"
  }
];

const lanes = [
  {
    label: "KAI notebook",
    title: "主線文章",
    copy: "個人筆記感，拆概念、建心智模型，把 Kubernetes 寫成可以一路讀下去的故事。",
    href: "/series/kai-k8s-road/"
  },
  {
    label: "Production field notes",
    title: "事故與現場",
    copy: "probe、rollout、GitOps、observability 的現場筆記，保留排查順序和誤判點。",
    href: "/blog/"
  },
  {
    label: "Concept artifact",
    title: "概念拆解",
    copy: "把抽象概念變成一個能記住的 mental object，不只背名詞。",
    href: "/tags/"
  }
];
---

<BaseLayout
  title="KAI K8s之路"
  description="KAI K8s之路：Kai Ning 的 Kubernetes 個人技術主線，用 infra notebook 的方式把 Pod、Deployment、Service、GitOps 與 production lessons 串成一條可反覆回看的路。"
  lang="zh-Hant"
  keywords={[
    "Kubernetes blog",
    "KAI K8s之路",
    "Kubernetes 教學",
    "GitOps",
    "observability",
    "AI infra"
  ]}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE_TITLE,
      alternateName: FEATURED_SERIES_NAME,
      url: "https://lemonkai.github.io/",
      description:
        "Kai Ning's bilingual Kubernetes and infrastructure notebook, centered on KAI K8s之路.",
      inLanguage: ["zh-Hant", "en"]
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      name: SITE_AUTHOR,
      url: "https://lemonkai.github.io/",
      sameAs: ["https://github.com/LemonKAI", "https://www.instagram.com/kaikai_blog/"]
    }
  ]}
>
  <section class="hero hero--home hero--notebook">
    <div class="hero__copy">
      <p class="eyebrow">KAI notebook / mainline infrastructure writing</p>
      <h1>把 Kubernetes 寫成一條能被記住的路。</h1>
      <p class="hero__eyeline">
        KAI K8s之路不是文章列表，是一條從 Pod 長到 production 的心智路線。
      </p>
      <p class="hero__lede">
        我不想把這裡做成雲原生百科。這裡更像一本持續增長的 infra notebook：先把一個概念放進自己的理解裡，再把它接到下一個問題。讀者看完不是只知道名詞，而是能帶走一個可以回來用的判斷。
      </p>

      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">進入 KAI K8s 主線</a>
        <a class="button" href="/blog/zh/">中文文章</a>
        <a class="button" href="/blog/en/">English track</a>
        <a class="button" href="https://www.instagram.com/kaikai_blog/" rel="noreferrer">@kaikai_blog</a>
      </div>

      <dl class="hero__ledger hero__ledger--notebook">
        <div>
          <dt>Core sentence</dt>
          <dd>每篇都要有一句能記住的核心判斷。</dd>
        </div>
        <div>
          <dt>Mental model</dt>
          <dd>每個概念都要變成一個讀者能帶走的模型。</dd>
        </div>
        <div>
          <dt>Story chain</dt>
          <dd>每章都要能自然接到下一個 Kubernetes 問題。</dd>
        </div>
      </dl>
    </div>

    <aside class="signal-panel signal-panel--route">
      <p class="signal-panel__label">Reading route / 主線路徑</p>
      <ol class="chapter-path">
        {route.map((item) => (
          <li class="chapter-step">
            <span>{item.step}</span>
            <div>
              <strong>{item.title}</strong>
              <p>{item.detail}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="signal-panel__metrics">
        <div>
          <strong>{seriesPosts.length}</strong>
          <span>published chapters</span>
        </div>
        <div>
          <strong>{incidentPosts.length}</strong>
          <span>incident notes</span>
        </div>
        <div>
          <strong>{notePosts.length}</strong>
          <span>quick notes</span>
        </div>
        <div>
          <strong>{seriesPairs.length}</strong>
          <span>bilingual pairs</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Writing constitution</p>
      <h2>這個站的文章應該怎麼長出來</h2>
    </div>
  </section>

  <section class="principle-strip">
    {principles.map((item) => (
      <article class="principle-card">
        <span aria-hidden="true"></span>
        <h3>{item.title}</h3>
        <p>{item.copy}</p>
      </article>
    ))}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Content lanes</p>
      <h2>主線、現場、概念，各自有自己的寫法</h2>
    </div>
  </section>

  <section class="lane-grid">
    {lanes.map((lane) => (
      <a class="lane-card" href={lane.href}>
        <p class="eyebrow">{lane.label}</p>
        <h3>{lane.title}</h3>
        <p>{lane.copy}</p>
      </a>
    ))}
  </section>

  {
    featuredPair && (
      <>
        <section class="section-header">
          <div>
            <p class="eyebrow">Current chapter</p>
            <h2>先從正在成形的這一章開始</h2>
          </div>
          <a class="inline-link" href="/series/kai-k8s-road/">進入系列頁</a>
        </section>

        <section class="chapter-stack">
          <SeriesPairRow pair={featuredPair} />
        </section>
      </>
    )
  }

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>支線不是雜訊，是主線的現場回聲</h2>
    </div>
    <a class="inline-link" href="/blog/">View full archive</a>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Topic map</p>
      <h2>目前主題分布</h2>
    </div>
  </section>

  <section class="mini-grid">
    {topTags.map(({ tag, count }) => (
      <article class="mini-card">
        <strong>{tag}</strong>
        <span>{count} post{count > 1 ? "s" : ""}</span>
      </article>
    ))}
  </section>
</BaseLayout>
