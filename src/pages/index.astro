---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SeriesPairRow from "../components/SeriesPairRow.astro";
import { FEATURED_SERIES_NAME, SITE_AUTHOR, SITE_TITLE } from "../consts";
import {
  getPostsByKind,
  getSeriesPosts,
  getSortedPosts,
  getTranslationPairs,
  getTagCounts,
  sortSeriesPosts
} from "../utils/blog";

const posts = await getSortedPosts();
const topTags = getTagCounts(posts).slice(0, 6);
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const seriesPairs = getTranslationPairs(seriesPosts);
const featuredPair = seriesPairs[0];
const sidePosts = posts.filter((post) => post.data.kind !== "series").slice(0, 4);
const notePosts = getPostsByKind(posts, "note");
const incidentPosts = getPostsByKind(posts, "incident");

const route = [
  { step: "01", title: "Pod", detail: "先知道 Kubernetes 到底在照顧哪一組程式。" },
  { step: "02", title: "Deployment", detail: "再理解更新、回滾與 rollout 怎麼發生。" },
  { step: "03", title: "Service", detail: "接著看流量如何找到 workload。" },
  { step: "04", title: "Probe", detail: "把健康檢查和重啟邏輯拆開。" },
  { step: "05", title: "GitOps", detail: "最後把變更放進可審計的提交歷史。" }
];

const principles = [
  {
    title: "不是課綱，是筆記本",
    copy: "每篇先寫清楚：這個資源切哪個邊界、出事時先看哪裡、下一章會逼出什麼問題。"
  },
  {
    title: "不是摘要，是 KAI 的判斷",
    copy: "同一個 Kubernetes 概念，要寫出我會怎麼記、怎麼 debug、怎麼把它放回 production 行為。"
  },
  {
    title: "每章都要有生活例子",
    copy: "先用一個好懂的例子抓直覺，再回到 Pod、controller、traffic、probe 這些專業邊界。"
  }
];

const lanes = [
  {
    label: "Mainline notebook",
    title: "主線筆記",
    copy: "個人筆記感，先講生活例子，再拆概念、建心智模型，把 Kubernetes 寫成好懂但不降級的專業筆記。",
    href: "/series/kai-k8s-road/"
  },
  {
    label: "Field notes",
    title: "排查筆記",
    copy: "probe、rollout、GitOps、observability 的現場筆記，保留訊號、排查順序和誤判點。",
    href: "/blog/"
  },
  {
    label: "Concept model",
    title: "概念模型",
    copy: "把抽象概念變成一個能記住的 mental object，不只背名詞。",
    href: "/tags/"
  }
];
---

<BaseLayout
  title="KAI K8s之路"
  description="KAI K8s之路：Kai Ning 的 Kubernetes 主線筆記。用生活例子建立直覺，再回到 Pod、Deployment、Service、Probe、GitOps 的專業邊界與 production 行為。"
  lang="zh-Hant"
  keywords={[
    "Kubernetes blog",
    "KAI K8s之路",
    "Kubernetes 心智模型",
    "GitOps",
    "observability",
    "AI infra"
  ]}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE_TITLE,
      alternateName: FEATURED_SERIES_NAME,
      url: "https://lemonkai.github.io/",
      description:
        "Kai Ning 的繁中 Kubernetes infra notebook，主線是 KAI K8s之路，英文版作為 mirror。",
      inLanguage: ["zh-Hant", "en"]
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      name: SITE_AUTHOR,
      url: "https://lemonkai.github.io/",
      sameAs: ["https://github.com/LemonKAI", "https://www.instagram.com/kaikai_blog/"]
    }
  ]}
>
  <section class="hero hero--home hero--notebook">
    <div class="hero__copy">
      <p class="eyebrow">KAI notebook / Kubernetes mainline</p>
      <h1>把 Kubernetes 寫成好懂又專業的筆記。</h1>
      <p class="hero__eyeline">
        KAI K8s之路是我的 Kubernetes 主線筆記：先用生活例子抓直覺，再回到資源邊界和 production 行為。
      </p>
      <p class="hero__lede">
        我不想先背 YAML，也不想把這裡做成雲原生百科。這裡更像一本持續增長的 infra notebook：先把概念變成能理解的畫面，再把它接回 debug、設計與真實環境裡會出事的地方。
      </p>

      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">進入 KAI K8s 主線</a>
        <a class="button" href="/blog/zh/">中文文章</a>
        <a class="button" href="/blog/en/">English mirror</a>
        <a class="button" href="https://www.instagram.com/kaikai_blog/" rel="noreferrer">@kaikai_blog</a>
      </div>

      <dl class="hero__ledger hero__ledger--notebook">
        <div>
          <dt>先記這句</dt>
          <dd>每篇都要有一句能記住的核心判斷。</dd>
        </div>
        <div>
          <dt>生活例子</dt>
          <dd>每章都要用一個簡單例子先把直覺搭起來。</dd>
        </div>
        <div>
          <dt>排查用途</dt>
          <dd>最後要說清楚這個模型出事時能怎麼用。</dd>
        </div>
      </dl>
    </div>

    <aside class="signal-panel signal-panel--route">
      <p class="signal-panel__label">Chapter index / 章節索引</p>
      <ol class="chapter-path">
        {route.map((item) => (
          <li class="chapter-step">
            <span>{item.step}</span>
            <div>
              <strong>{item.title}</strong>
              <p>{item.detail}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="signal-panel__metrics">
        <div>
          <strong>{seriesPosts.length}</strong>
          <span>主線章節</span>
        </div>
        <div>
          <strong>{incidentPosts.length}</strong>
          <span>排查筆記</span>
        </div>
        <div>
          <strong>{notePosts.length}</strong>
          <span>概念模型</span>
        </div>
        <div>
          <strong>{seriesPairs.length}</strong>
          <span>English mirrors</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Notebook rules</p>
      <h2>這個站的筆記怎麼寫</h2>
    </div>
  </section>

  <section class="principle-strip">
    {principles.map((item) => (
      <article class="principle-card">
        <span aria-hidden="true"></span>
        <h3>{item.title}</h3>
        <p>{item.copy}</p>
      </article>
    ))}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Notebook sections</p>
      <h2>主線、排查、概念，各自有自己的用法</h2>
    </div>
  </section>

  <section class="lane-grid">
    {lanes.map((lane) => (
      <a class="lane-card" href={lane.href}>
        <p class="eyebrow">{lane.label}</p>
        <h3>{lane.title}</h3>
        <p>{lane.copy}</p>
      </a>
    ))}
  </section>

  {
    featuredPair && (
      <>
        <section class="section-header">
          <div>
            <p class="eyebrow">Current chapter</p>
            <h2>先從第一個邊界開始</h2>
          </div>
          <a class="inline-link" href="/series/kai-k8s-road/">進入系列頁</a>
        </section>

        <section class="chapter-stack">
          <SeriesPairRow pair={featuredPair} />
        </section>
      </>
    )
  }

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>支線筆記用來補主線沒說完的現場行為</h2>
    </div>
    <a class="inline-link" href="/blog/">看全部文章</a>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Topic map</p>
      <h2>目前筆記主題</h2>
    </div>
  </section>

  <section class="mini-grid">
    {topTags.map(({ tag, count }) => (
      <article class="mini-card">
        <strong>{tag}</strong>
        <span>{count} post{count > 1 ? "s" : ""}</span>
      </article>
    ))}
  </section>
</BaseLayout>
