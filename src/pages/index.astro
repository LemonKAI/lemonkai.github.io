---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SeriesPairRow from "../components/SeriesPairRow.astro";
import { FEATURED_SERIES_NAME } from "../consts";
import {
  getPostsByKind,
  getSeriesPosts,
  getSortedPosts,
  getTranslationPairs,
  getTagCounts,
  sortSeriesPosts
} from "../utils/blog";

const posts = await getSortedPosts();
const topTags = getTagCounts(posts).slice(0, 6);
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const seriesPairs = getTranslationPairs(seriesPosts);
const featuredPair = seriesPairs[0];
const sidePosts = posts.filter((post) => post.data.kind !== "series").slice(0, 4);
const notePosts = getPostsByKind(posts, "note");
const incidentPosts = getPostsByKind(posts, "incident");

const roadmap = [
  { title: "01", detail: "Container → Pod" },
  { title: "02", detail: "Deployment / rollout" },
  { title: "03", detail: "Service / Ingress" },
  { title: "04", detail: "Config / Probe / Secret" },
  { title: "05", detail: "Observability / GitOps" },
  { title: "06", detail: "Incidents / production notes" }
];
---

<BaseLayout
  title="KAI K8s之路"
  description="KAI K8s之路：從 Kubernetes 基礎一路寫到實際生產環境，並同步提供 English version。"
  lang="zh-Hant"
>
  <section class="hero hero--home">
    <div class="hero__copy">
      <p class="eyebrow">KAI notebook / bilingual infrastructure writing</p>
      <h1>把 Kubernetes 寫成一條會一直回頭用的主線。</h1>
      <p class="hero__eyeline">
        KAI K8s之路 是主線；GitOps、incident notes、AI infra 都是沿路長出的 field notes。
      </p>
      <p class="hero__lede">
        這裡不想做成模板味太重的 tech blog，而更像一本持續增長的技術筆記。主線先把
        Kubernetes 的抽象、rollout、GitOps 與 incident lessons 寫成一條路；其他 quick tips
        和事故片段，則留在旁邊持續長出來。
      </p>

      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">看系列入口</a>
        <a class="button" href="/blog/zh/">看中文版</a>
        <a class="button" href="/blog/en/">Read English version</a>
      </div>

      <dl class="hero__ledger">
        <div>
          <dt>Reading spine</dt>
          <dd>從 Pod、Deployment 一路走到 observability / GitOps / incidents</dd>
        </div>
        <div>
          <dt>Notebook edges</dt>
          <dd>Quick tips、rollout scars、production-side lessons</dd>
        </div>
        <div>
          <dt>Language rhythm</dt>
          <dd>中文先講透，English track 也能對外讀</dd>
        </div>
      </dl>
    </div>

    <aside class="signal-panel">
      <p class="signal-panel__label">Series spine / 主線骨架</p>
      <ol class="roadmap-list">
        {roadmap.map((item) => (
          <li>
            <strong>{item.title}</strong>
            <span>{item.detail}</span>
          </li>
        ))}
      </ol>

      <div class="signal-panel__metrics">
        <div>
          <strong>{seriesPosts.length}</strong>
          <span>published chapters</span>
        </div>
        <div>
          <strong>{incidentPosts.length}</strong>
          <span>incident notes</span>
        </div>
        <div>
          <strong>{notePosts.length}</strong>
          <span>quick notes</span>
        </div>
        <div>
          <strong>{seriesPairs.length}</strong>
          <span>bilingual chapter pairs</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Notebook guide</p>
      <h2>這個站怎麼讀，才會讀到主線</h2>
    </div>
  </section>

  <section class="section-grid section-grid--manifesto">
    <article class="feature-card">
      <p class="eyebrow">主線 / Backbone</p>
      <h2>先讀系列，再讀邊角</h2>
      <p>
        <strong>KAI K8s之路</strong> 不是普通分類，而是整個站的骨架。從 Pod 開始，慢慢走到
        rollout、observability、GitOps 與 incident handling。
      </p>
    </article>

    <article class="feature-card">
      <p class="eyebrow">雙語 / Rhythm</p>
      <h2>中英不是切換，是兩條並排的閱讀軌</h2>
      <p>
        中文負責把概念講紮實，英文負責讓整條路也能對外輸出。系列盡量成對出現，支線則保留語言彈性。
      </p>
    </article>

    <article class="feature-card">
      <p class="eyebrow">側邊欄 / Field notes</p>
      <h2>小知識和事故趣事，放第二層但要保持活著</h2>
      <ul class="focus-list">
        <li>probe / rollout / GitOps 類經驗會快速穿插</li>
        <li>incident notes 保留現場感，不硬包成正規教材</li>
        <li>所有支線都應該回頭補強主線理解</li>
      </ul>
    </article>
  </section>

  {
    featuredPair && (
      <>
        <section class="section-header">
          <div>
            <p class="eyebrow">Current chapter</p>
            <h2>先從正在成形的這一章開始</h2>
          </div>
          <a class="inline-link" href="/series/kai-k8s-road/">進入系列頁</a>
        </section>

        <section class="chapter-stack">
          <SeriesPairRow pair={featuredPair} />
        </section>
      </>
    )
  }

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>次要但活著的筆記區</h2>
    </div>
    <a class="inline-link" href="/blog/">View full archive</a>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Topic map</p>
      <h2>目前主題分布</h2>
    </div>
  </section>

  <section class="mini-grid">
    {topTags.map(({ tag, count }) => (
      <article class="mini-card">
        <strong>{tag}</strong>
        <span>{count} post{count > 1 ? "s" : ""}</span>
      </article>
    ))}
  </section>
</BaseLayout>
