---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import SeriesPairRow from "../../components/SeriesPairRow.astro";
import { FEATURED_SERIES_NAME } from "../../consts";
import {
  getPostsByKind,
  getPostsByLang,
  getSeriesPosts,
  getSortedPosts,
  getTranslationPairs,
  sortSeriesPosts
} from "../../utils/blog";

const posts = await getSortedPosts();
const zhPosts = getPostsByLang(posts, "zh");
const enPosts = getPostsByLang(posts, "en");
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const seriesPairs = getTranslationPairs(seriesPosts);
const sidePosts = getPostsByKind(posts, "incident").concat(
  posts.filter((post) => post.data.kind === "note").slice(0, 3)
);
---

<BaseLayout
  title="Blog"
  description="Bilingual Kubernetes writing by Kai Ning, with the KAI K8s journey series, quick notes, and production lessons."
  lang="zh-Hant"
>
  <section class="page-intro page-intro--with-rail">
    <div class="page-intro__copy">
      <p class="eyebrow">Archive / 全站文章庫</p>
      <h1>主線是 KAI K8s之路，其餘內容都該繞著它讀</h1>
      <p>
        這裡不是把所有文章平鋪展示，而是先把雙語系列
        <strong>{FEATURED_SERIES_NAME}</strong> 放在前景。其他 Kubernetes、GitOps、
        observability 與事故筆記，則作為 field notes 穿插更新。
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">系列入口</a>
        <a class="button" href="/blog/zh/">看中文版</a>
        <a class="button" href="/blog/en/">Read English track</a>
      </div>
    </div>

    <aside class="page-intro__aside">
      <p class="signal-panel__label">Archive shape / 結構</p>
      <ul class="signal-panel__list">
        <li>章節式雙語主線放在最前面</li>
        <li>中文與 English archives 保留獨立入口</li>
        <li>quick tips 與 incidents 留在後段閱讀</li>
      </ul>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Series spine</p>
      <h2>KAI K8s之路 / KAI&apos;s K8s Journey</h2>
    </div>
  </section>

  <section class="chapter-stack">
    {seriesPairs.map((pair) => <SeriesPairRow pair={pair} />)}
  </section>

  <section class="language-split">
    <article class="language-panel">
      <p class="eyebrow">中文內容</p>
      <h2>中文主線與補充筆記</h2>
      <p>先把概念講清楚，再一路走到 rollout、GitOps 與真實環境裡的坑。</p>
      <a class="inline-link" href="/blog/zh/">查看全部中文文章</a>
      <div class="language-panel__count">{zhPosts.length} 篇</div>
    </article>

    <article class="language-panel">
      <p class="eyebrow">English track</p>
      <h2>English notes with production bias</h2>
      <p>Keep the series readable in English while leaving room for operational notes.</p>
      <a class="inline-link" href="/blog/en/">Browse English posts</a>
      <div class="language-panel__count">{enPosts.length} posts</div>
    </article>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>現場補充、小知識、事故趣事與建議</h2>
    </div>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.slice(0, 4).map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
