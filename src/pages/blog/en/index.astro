---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { FEATURED_SERIES_NAME } from "../../../consts";
import {
  getPostsByKind,
  getPostsByLang,
  getSeriesPosts,
  getSortedPosts,
  sortSeriesPosts
} from "../../../utils/blog";

const posts = getPostsByLang(await getSortedPosts(), "en");
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const sidePosts = getPostsByKind(posts, "note").concat(
  getPostsByKind(posts, "incident")
);
---

<BaseLayout
  title="English posts"
  description="English mirror of Kai Ning's Chinese-first Kubernetes notebook, centered on KAI K8s之路 and selected operational notes."
  alternates={[{ href: "/blog/zh/", lang: "zh-Hant" }]}
>
  <section class="page-intro page-intro--with-rail">
    <div class="page-intro__copy">
      <p class="eyebrow">English mirror</p>
      <h1>KAI K8s之路 — English mirror</h1>
      <p>
        These posts mirror the Chinese-first Kubernetes notebook for sharing and technical reference.
        The fuller voice, examples, and notebook rhythm live in the Traditional Chinese original.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">Open K8s notebook</a>
        <a class="button" href="/blog/zh/">Read Chinese original</a>
      </div>
    </div>

    <aside class="page-intro__aside">
      <p class="signal-panel__label">Mirror logic</p>
      <ul class="signal-panel__list">
        <li>This is the mirror, not the primary voice</li>
        <li>Use it for English reference and external sharing</li>
        <li>Switch to Chinese for the fuller notebook version</li>
      </ul>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Mirrored mainline</p>
      <h2>{FEATURED_SERIES_NAME}</h2>
    </div>
  </section>

  <section class="post-list">
    {seriesPosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>Mirrored field notes and operating rules</h2>
    </div>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
