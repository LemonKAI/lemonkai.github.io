---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { FEATURED_SERIES_NAME } from "../../../consts";
import {
  getPostsByKind,
  getPostsByLang,
  getSeriesPosts,
  getSortedPosts,
  sortSeriesPosts
} from "../../../utils/blog";

const posts = getPostsByLang(await getSortedPosts(), "zh");
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const sidePosts = getPostsByKind(posts, "incident").concat(
  getPostsByKind(posts, "note")
);
---

<BaseLayout
  title="中文文章"
  description="KAI K8s之路繁中主稿：用生活例子建立 Kubernetes 直覺，再回到專業邊界、排查筆記與操作守則。"
  lang="zh-Hant"
  alternates={[{ href: "/blog/en/", lang: "en" }]}
>
  <section class="page-intro page-intro--with-rail">
    <div class="page-intro__copy">
      <p class="eyebrow">繁中主稿 / Chinese original</p>
      <h1>KAI K8s之路的中文主線</h1>
      <p>
        這裡優先放系列繁中主稿：每章先用生活例子讓人容易理解，再回到 Kubernetes 真正的技術邊界。
        旁邊會收錄排查筆記、操作守則與概念模型。
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">看 K8s之路</a>
        <a class="button" href="/blog/en/">English mirror</a>
      </div>
    </div>

    <aside class="page-intro__aside">
      <p class="signal-panel__label">Reading logic / 閱讀方式</p>
      <ul class="signal-panel__list">
        <li>先用生活例子抓直覺</li>
        <li>再看 Kubernetes 資源真正負責哪段邊界</li>
        <li>想對外表達時，再切換 English mirror 看對照</li>
      </ul>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Series in Chinese</p>
      <h2>用好懂的例子建立專業直覺</h2>
    </div>
  </section>

  <section class="post-list">
    {seriesPosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>排查筆記與操作守則</h2>
    </div>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
