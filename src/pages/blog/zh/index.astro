---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { FEATURED_SERIES_NAME } from "../../../consts";
import {
  getPostsByKind,
  getPostsByLang,
  getSeriesPosts,
  getSortedPosts,
  sortSeriesPosts
} from "../../../utils/blog";

const posts = getPostsByLang(await getSortedPosts(), "zh");
const seriesPosts = sortSeriesPosts(getSeriesPosts(posts, FEATURED_SERIES_NAME));
const sidePosts = getPostsByKind(posts, "incident").concat(
  getPostsByKind(posts, "note")
);
---

<BaseLayout
  title="中文文章"
  description="KAI K8s之路中文內容：Kubernetes 基礎、事故趣事、小知識與實戰建議。"
  lang="zh-Hant"
>
  <section class="page-intro page-intro--with-rail">
    <div class="page-intro__copy">
      <p class="eyebrow">中文內容 / Chinese track</p>
      <h1>KAI K8s之路的中文主線</h1>
      <p>
        這裡優先放系列中文稿，讓整條路能從基礎一路走到實戰。中間也會穿插事故趣事、
        小知識與實際上比較值錢的建議。
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/series/kai-k8s-road/">看系列入口</a>
        <a class="button" href="/blog/en/">Read English track</a>
      </div>
    </div>

    <aside class="page-intro__aside">
      <p class="signal-panel__label">Reading order / 閱讀順序</p>
      <ul class="signal-panel__list">
        <li>先用中文主線把概念和直覺建立起來</li>
        <li>遇到 field notes，再拿來補強對主線的理解</li>
        <li>想對外表達時，再切換 English track 看對照</li>
      </ul>
    </aside>
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Series in Chinese</p>
      <h2>先把核心概念與直覺建立起來</h2>
    </div>
  </section>

  <section class="post-list">
    {seriesPosts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Field notes</p>
      <h2>中文補充筆記</h2>
    </div>
  </section>

  <section class="post-list post-list--secondary">
    {sidePosts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
