---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  updatedTime?: Date;
  keywords?: string[];
  noindex?: boolean;
  alternates?: Array<{
    href: string;
    lang: string;
  }>;
  schema?: Record<string, any> | Array<Record<string, any>>;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = "/og-default.svg",
  lang = "en",
  type = "website",
  publishedTime,
  updatedTime,
  keywords = [],
  noindex = false,
  alternates = [],
  schema
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = Astro.url.toString();
const siteBase = Astro.site ?? Astro.url;
const socialImage = new URL(image, siteBase).toString();
const locale = lang.startsWith("zh") ? "zh_HK" : "en_US";
const robotsContent = noindex
  ? "noindex,follow,max-image-preview:large"
  : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
const alternateLinks = alternates.map((alternate) => ({
  ...alternate,
  href: new URL(alternate.href, siteBase).toString(),
  locale: alternate.lang.startsWith("zh") ? "zh_HK" : "en_US"
}));
const baseSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  headline: pageTitle,
  description,
  url: canonicalUrl,
  inLanguage: lang,
  image: socialImage,
  author: {
    "@type": "Person",
    name: SITE_AUTHOR
  }
};
const schemaNodes = [baseSchema].concat(schema ? (Array.isArray(schema) ? schema : [schema]) : []);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={SITE_AUTHOR} />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#08111f" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    {
      alternateLinks.map((alternate) => (
        <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
      ))
    }

    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content={locale} />
    {
      alternateLinks.map((alternate) => (
        <meta property="og:locale:alternate" content={alternate.locale} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    {publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {updatedTime && (
      <meta property="article:modified_time" content={updatedTime.toISOString()} />
    )}
    {
      type === "article" && keywords.map((keyword) => <meta property="article:tag" content={keyword} />)
    }

    <script type="application/ld+json" set:html={JSON.stringify(schemaNodes)} />

    <title>{pageTitle}</title>
  </head>

  <body>
    <div class="page-shell">
      <SiteHeader lang={lang} />
      <main class="shell page-content">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
